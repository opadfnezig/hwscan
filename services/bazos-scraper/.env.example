# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=bazos.listings

# ── Redis ──────────────────────────────────────────────────────────────────
# Redis is started by this compose stack; override if using external Redis.
# REDIS_URL=redis://your-redis-host:6379

# ── Scraper ────────────────────────────────────────────────────────────────
BASE_URL=https://pc.bazos.cz/
SCAN_INTERVAL_MS=600000       # 10 minutes
SEEN_URL_LIMIT=1000           # ring buffer size for dedup

# ── Workers ────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2          # concurrent jobs per worker container

# ── Controller API ─────────────────────────────────────────────────────────
HTTP_PORT=3000
